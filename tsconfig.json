{
    "compilerOptions": {
        "allowJs": false,
        "esModuleInterop": true,
        "jsx": "react-jsx",
        "lib": ["DOM", "DOM.Iterable", "ES2022"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "noEmit": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "strict": true,
        "target": "ES2022",
        "types": ["vite/client", "react", "react-dom"]
    },
    "include": ["resources/js/**/*.ts", "resources/js/**/*.tsx"]
}
