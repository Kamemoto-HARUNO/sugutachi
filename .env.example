APP_NAME="すぐタチ"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
ADMIN_SEED_EMAIL=admin@sugutachi.local
ADMIN_SEED_PASSWORD=password
ADMIN_SEED_NAME="ローカル管理者"

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sugutachi_local
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000,sugutachi.com,www.sugutachi.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

STRIPE_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=jpy
STRIPE_CONNECT_COUNTRY=JP
STRIPE_CONNECT_RETURN_URL=${APP_URL}/therapist/stripe-connect
STRIPE_CONNECT_REFRESH_URL=${APP_URL}/therapist/stripe-connect
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT="${APP_NAME} location-search"
SERVICE_DOMAIN=sugutachi.com
SERVICE_BASE_URL=https://sugutachi.com
SERVICE_SUPPORT_EMAIL=support@sugutachi.com
SERVICE_COMMERCE_OPERATOR_NAME=
SERVICE_COMMERCE_REPRESENTATIVE_NAME=
SERVICE_COMMERCE_ADDRESS=
SERVICE_COMMERCE_PHONE_NUMBER=
SERVICE_COMMERCE_INQUIRY_HOURS=
SERVICE_COMMERCE_PAYMENT_TIMING="予約時にクレジットカード決済"
SERVICE_COMMERCE_SERVICE_DELIVERY_TIMING="予約成立後、予約日時にリラクゼーション役務を提供"
SERVICE_COMMERCE_CANCELLATION_POLICY_SUMMARY="キャンセル時刻と予約状態に応じて所定のキャンセル料が発生します。詳細は特定商取引法に基づく表記をご確認ください。"
SERVICE_COMMERCE_REFUND_POLICY_SUMMARY="返金可否はキャンセル時刻、役務提供状況、個別審査結果に応じて判断します。"
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT="mailto:support@sugutachi.com"
GTM_ENABLED=false
GTM_CONTAINER_ID=
GTM_AUTH=
GTM_PREVIEW=

VITE_APP_NAME="${APP_NAME}"
